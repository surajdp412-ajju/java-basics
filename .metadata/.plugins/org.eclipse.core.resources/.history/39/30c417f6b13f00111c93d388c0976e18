package Array;

public class PassArrayToMethod {
	
	// here we are creating a method which is accepting array as a parameter and we are performing by doing implementation //  
	
	public static void findMin(int arrayOne[]){ //  array is accepeted as an argument 
		
		int min = arrayOne[0];
		
		for(int i=1; i < arrayOne.length; i++ ){
			
			if(min>arrayOne[i]){
				min = arrayOne[i];
			}
		}
		
		System.out.println("Minimum Element is " + min);
		
	}
	
	// to return the array
	
	public static int[] getArray(){
		
		return new int[] {12,13,56,78,90,12,34};
	}
	

	public static void main(String[] args) { //  we are declaring the array and passing it into particular method // 
		
		PassArrayToMethod pass = new PassArrayToMethod();
		
		int arrayTest[] = {12,16,18,30,7,9};
		
		pass.findMin(arrayTest);
		
		int arrayThree[] = pass.getArray(); // we are initialize an array with the help of getarray 		

		System.out.println(arrayThree[2]);
	}

}
