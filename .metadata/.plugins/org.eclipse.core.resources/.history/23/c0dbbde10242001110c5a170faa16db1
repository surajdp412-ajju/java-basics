package Iterator;

import java.util.Enumeration;
import java.util.Vector;

public class EnumerationTest{
	
	public static void main (String args[]){
		
		//Create a vector and print its contents
		Vector v = new Vector();
		for (int i = 0; i < 10; i++){
			v.addElement(i); // this is the add element of the vector class
			
		}
		
		//[0,1,2,3,..........]
		
		System.out.println(v);
		
		// here we are using the object class integration in enumeration
		
		// At beginning e(cursor) will point to
		// index just before the first element in v
		Enumeration e = v.elements();
		
		//Checking the next element availability
		while (e.hasMoreElements()){ // while loop is used to check if the results are pulling upto date
			//moving cursor to next element
			int i = (Integer) e.nextElement(); // next element is returning the object 
			
			System.out.println(i + " ");
		}
	}
} 

