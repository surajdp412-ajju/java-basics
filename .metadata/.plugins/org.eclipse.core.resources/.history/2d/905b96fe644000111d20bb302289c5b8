package ExceptionalHandling;

public class FinalBlock {

	public static void main(String[] args) {
		
		try{		
		String text = "Suraj";
		System.out.println(text);
		
		String text1 = null;
		System.out.println(text1.length());
		
		} finally{
			System.out.println("Hi, I am inside the finally Block");
		}
		
	}

}
