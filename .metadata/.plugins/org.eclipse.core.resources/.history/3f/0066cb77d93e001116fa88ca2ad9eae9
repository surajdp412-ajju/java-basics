// Static and Keywords in Java // 

public class CounterClass {
	
	int i = 0;
	static int j = 0; // here we have made j variable static //

	public static void main(String[] args) {
		
		CounterClass counter = new CounterClass();
		CounterClass counter2 = new CounterClass();
		
		System.out.println(counter.i); // here i is non static so it belongs to class object so we have declared counter a new class object for it//
		System.out.println(counter2.i);
		
		System.out.println(CounterClass.j);// here j is static so belongs to class no need to declare new class object//
		
	}

}
