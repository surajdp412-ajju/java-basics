
public class Dog { // to define the state of the class that is Dog we are adding few variables that are name, breed, height etc which also acts as a behavior of the class (collection of objects)//
	
	String name = "Jacky";
	String breed = "BullDog";
	int height = 4;
	
	public void barking (){ // there are the behavior defined for the class dog//
		System.out.println(name + "is barking");
	}
	
	public void eating (){
		System.out.println(name + " is eating");
	}

	public static void main(String[] args) {
		
		Dog dogclass = new Dog();// creating the new object with the help of new keyword in Java inside the main method -> this is initalizing the object inside the main body class
		Dog obj2 = new Dog();
		
		System.out.println(dogclass.height); // here the dogclass is the object of this class which is already declared above so that we can use it now as required //
		
		dogclass.barking();
		obj2.barking(); // here we can see once defined object can be used multiple times
		


	}

}
