package ListInterface;

import java.util.ArrayList;
import java.util.List;

public class ListDemo {

	public static void main(String[] args) {
		
		List l1 = new ArrayList();
		
		// void add method //
		
		
		l1.add(0, 12);
		l1.add(1, 14);
		
		System.out.println("elements added using void add method: " + l1);
		
		// Boolean addAll method //
		
		List l2 = new ArrayList();
		l2.add(10);
		l2.add(11);
		l2.add(132);
		l2.add(165);
		l2.add(187);
		
		l1.addAll(0, l2);
		
		System.out.println("elements using void add method: " + l2);		
		System.out.println("mulitple elements added using Bollean addAll method: " + l1);
		
		// Object removal method //
		
		l1.remove(3);
		System.out.println("element removed using object removal method: " + l1);
		
		// Get method//
		
		System.out.println("Index present at index 5: " + l1.get(5));
		
		// Set method - to replace the element at the index level //
		
		l1.set(5, 122);
		System.out.println("After the set operator: " + l1);
		
		
		
		
		
		
		

	}

}
